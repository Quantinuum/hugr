@0 = private unnamed_addr constant [58 x i8] c"Float value too big to convert to int of given width (32)\00", align 1

define internal { i1, { i32, ptr }, i32 } @_hl.main.1(double %0) !dbg !3 {
alloca_block:
  %"0" = alloca { i1, { i32, ptr }, i32 }, align 8
  %"2_0" = alloca double, align 8
  %"4_0" = alloca { i1, { i32, ptr }, i32 }, align 8
  br label %entry_block

entry_block:                                      ; preds = %alloca_block
  store double %0, ptr %"2_0", align 8
  %"2_01" = load double, ptr %"2_0", align 8
  %within_upper_bound = fcmp olt double %"2_01", 0x41DFFFFFFFC00000, !dbg !15
  %within_lower_bound = fcmp ole double 0xC1E0000000000000, %"2_01", !dbg !15
  %success = and i1 %within_upper_bound, %within_lower_bound, !dbg !15
  %trunc_result = fptosi double %"2_01" to i32, !dbg !15
  %1 = insertvalue { i1, { i32, ptr }, i32 } { i1 true, { i32, ptr } poison, i32 poison }, i32 %trunc_result, 2, !dbg !15
  %2 = select i1 %success, { i1, { i32, ptr }, i32 } %1, { i1, { i32, ptr }, i32 } { i1 false, { i32, ptr } { i32 2, ptr @0 }, i32 poison }, !dbg !15
  store { i1, { i32, ptr }, i32 } %2, ptr %"4_0", align 8, !dbg !15
  %"4_02" = load { i1, { i32, ptr }, i32 }, ptr %"4_0", align 8
  store { i1, { i32, ptr }, i32 } %"4_02", ptr %"0", align 8
  %"03" = load { i1, { i32, ptr }, i32 }, ptr %"0", align 8
  ret { i1, { i32, ptr }, i32 } %"03"
}

