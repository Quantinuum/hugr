define internal { ptr, i64 } @_hl.main.1() !dbg !3 {
alloca_block:
  br label %entry_block

entry_block:                                      ; preds = %alloca_block
  %0 = mul i64 2, ptrtoint (ptr getelementptr (i64, ptr null, i32 1) to i64)
  %1 = call ptr @malloc(i64 %0)
  %2 = insertvalue { ptr, i64 } poison, ptr %1, 0
  %3 = insertvalue { ptr, i64 } %2, i64 0, 1
  %4 = getelementptr inbounds i64, ptr %1, i32 0
  store i64 1, ptr %4, align 4
  %5 = getelementptr inbounds i64, ptr %1, i32 1
  store i64 2, ptr %5, align 4
  ret { ptr, i64 } %3
}

declare ptr @malloc(i64)

