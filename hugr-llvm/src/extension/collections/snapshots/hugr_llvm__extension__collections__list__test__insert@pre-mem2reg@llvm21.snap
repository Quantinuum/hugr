define internal { ptr, { i1, i16 } } @_hl.main.1(ptr %0, i64 %1, i16 %2) !dbg !3 {
alloca_block:
  %"0" = alloca ptr, align 8
  %"1" = alloca { i1, i16 }, align 8
  %"2_0" = alloca ptr, align 8
